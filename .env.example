# Consumer Labs — environment variables
# Copia este archivo a .env.local y rellena tus valores

# ── Docker Hub ────────────────────────────────────────────────────────────────
# Tu usuario de Docker Hub (también configúralo como Variable en GitHub Actions)
DOCKERHUB_USERNAME=tuusuario

# Tag de imagen a desplegar (default: latest)
IMAGE_TAG=latest

# ── ElevenLabs TTS (opcional) ─────────────────────────────────────────────────
# Clave gratuita en https://elevenlabs.io — si está vacía usa Web Speech API
VITE_ELEVENLABS_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL que la app usa para conectarse a Ollama.
# En producción con docker compose: http://localhost/ollama
# En desarrollo local directo:      http://localhost:11434
