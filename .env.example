# Consumer Labs — environment variables
# Copy this file to .env.local and fill in your keys

# ElevenLabs API key (optional — get free key at https://elevenlabs.io)
# If left empty, the app falls back to Web Speech API
VITE_ELEVENLABS_API_KEY=

# Ollama is auto-detected at http://localhost:11434
# You can override the URL inside the app settings
